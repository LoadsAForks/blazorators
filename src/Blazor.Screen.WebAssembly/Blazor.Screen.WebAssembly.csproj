<Project Sdk="Microsoft.NET.Sdk.Razor">
  <PropertyGroup>
    <TargetFrameworks>$(DefaultTargetFrameworks)</TargetFrameworks>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <NoWarn>NU5125;NU5039;CS0108;CS0612;CS8766</NoWarn>
    <AssemblyName>Blazor.Screen.WebAssembly</AssemblyName>
    <RootNamespace>Blazor.Screen.WebAssembly</RootNamespace>
    <PackageId>Blazor.Screen.WebAssembly</PackageId>
    <Title>Blazor Screen WebAssembly - in-process DOM interop</Title>
    <Description>Generated Screen and Screen Orientation API bindings with synchronous and asynchronous dispatch for Blazor WebAssembly.</Description>
    <PackageTags>dotnet;blazor;webassembly;dom;interop;screen;screen-orientation</PackageTags>
    <PackageProjectUrl>https://github.com/IEvangelist/blazorators</PackageProjectUrl>
    <RepositoryUrl>https://github.com/IEvangelist/blazorators</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <Authors>David Pine</Authors>
    <PackageLicenseFile>LICENSE</PackageLicenseFile>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageIcon>logo.png</PackageIcon>
    <DomProfileName>Screen</DomProfileName>
    <DomProfileHost>WebAssembly</DomProfileHost>
  </PropertyGroup>

  <ItemGroup Label="Package files">
    <None Include="..\..\LICENSE" Pack="true" PackagePath="\" />
    <None Include="README.md" Pack="true" PackagePath="\" />
    <None Include="..\..\logo.png" Pack="true" PackagePath="\" />
  </ItemGroup>

  <Import Project="..\Blazor.DOM.FocusedPackage.props" />
</Project>
