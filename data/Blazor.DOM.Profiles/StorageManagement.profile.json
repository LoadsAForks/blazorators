  "memberIncludes": {
    "StorageManager": ["estimate", "getDirectory", "persist", "persisted"]
  },
  "entryPoints": [
    {
      "name": "StorageManager",
      "symbol": "StorageManager",
      "javaScriptPath": "navigator.storage"
    }
  ]
}
