{
  "$schema": "../Blazor.DOM/profiles.schema.json",
  "name": "SupplementalBrowserApis",
  "description": "Compact proof for pinned Web Bluetooth, WebUSB, WebHID, Web Serial, Presentation API, and WebGPU declarations.",
  "rootSymbols": [
    "Navigator",
    "Bluetooth",
    "BluetoothDevice",
    "BluetoothManufacturerDataMap",
    "BluetoothPermissionDescriptor",
    "BluetoothLEScanPermissionDescriptor",
    "BluetoothRemoteGATTCharacteristic",
    "USB",
    "USBDevice",
    "USBPermissionDescriptor",
    "HID",
    "HIDDevice",
    "HIDInputReportEvent",
    "Serial",
    "SerialPort",
    "Presentation",
    "PresentationRequest",
    "PresentationConnection",
    "PresentationConnectionAvailableEvent",
    "GPU",
    "GPUAdapter",
    "GPUDevice",
    "GPUBuffer",
    "GPUCanvasContext",
    "GPUQueue",
    "GPUSupportedFeatures",
    "WGSLLanguageFeatures",
    "GPUBufferUsage",
    "GPUMapMode",
    "GPUShaderStage",
    "GPUTextureUsage"
  ],
  "secureContext": true,
  "requiresUserActivation": true,
  "features": [
    "bluetooth",
    "usb",
    "hid",
    "serial",
    "presentation",
    "webgpu"
  ],
  "outputNamespace": "Blazor.DOM",
  "outputSubdirectory": "Profiles/SupplementalBrowserApis",
  "minimalDependencyContracts": true,
  "memberIncludes": {
    "Bluetooth": [
      "onavailabilitychanged",
      "requestDevice",
      "requestLEScan"
    ],
    "BluetoothDevice": [
      "gatt",
      "watchAdvertisements"
    ],
    "BluetoothRemoteGATTCharacteristic": [
      "value",
      "readValue",
      "writeValueWithResponse",
      "startNotifications"
    ],
    "USB": [
      "onconnect",
      "ondisconnect",
      "getDevices",
      "requestDevice"
    ],
    "USBDevice": [
      "configurations",
      "open",
      "transferIn",
      "transferOut"
    ],
    "HID": [
      "onconnect",
      "ondisconnect",
      "getDevices",
      "requestDevice"
    ],
    "HIDDevice": [
      "oninputreport",
      "open",
      "sendReport",
      "receiveFeatureReport"
    ],
    "Serial": [
      "onconnect",
      "ondisconnect",
      "getPorts",
      "requestPort"
    ],
    "SerialPort": [
      "onconnect",
      "ondisconnect",
      "readable",
      "writable",
      "open",
      "getSignals"
    ],
    "Presentation": [
      "defaultRequest",
      "receiver"
    ],
    "PresentationRequest": [
      "onconnectionavailable",
      "start",
      "reconnect"
    ],
    "PresentationConnection": [
      "onmessage",
      "state",
      "send"
    ],
    "GPU": [
      "wgslLanguageFeatures",
      "requestAdapter"
    ],
    "GPUAdapter": [
      "features",
      "limits",
      "info",
      "requestDevice"
    ],
    "GPUDevice": [
      "features",
      "limits",
      "queue",
      "lost",
      "onuncapturederror",
      "addEventListener",
      "removeEventListener",
      "createBuffer",
      "popErrorScope"
    ],
    "GPUBuffer": [
      "size",
      "usage",
      "mapAsync",
      "getMappedRange"
    ],
    "GPUCanvasContext": [
      "configure",
      "getConfiguration",
      "getCurrentTexture"
    ],
    "GPUQueue": [
      "submit",
      "writeBuffer",
      "onSubmittedWorkDone"
    ],
    "Navigator": [
      "bluetooth",
      "usb",
      "hid",
      "serial",
      "presentation",
      "gpu"
    ],
    "NavigatorGPU": ["gpu"],
    "EventListener": ["$callSignature"],
    "__GPUDeviceEventMap": ["uncapturederror"]
  }
}
