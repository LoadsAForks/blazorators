    async Task<DemoResult> ChooseFileAsync()
    {
        await using var window = await Browser.GetWindowProxyAsync();
        await using var handles = await window.ShowOpenFilePickerAsync(
            new OpenFilePickerOptions { Multiple = false });
        var count = await handles.GetLengthAsync();
        if (count == 0)
        {
            return CreateResult(
                "The browser returned no file handles.",
                "warning",
                new { selected = false, handleCount = 0 },
                new DemoFact("Selection", "Empty"));
        }

        await using var handle = await handles.GetAsync(0);
        await using var file = await handle.GetFileAsync();
        var lastModified = DateTimeOffset.FromUnixTimeMilliseconds((long)file.LastModified);
        return CreateResult(
            $"Selected {file.Name} ({FormatBytes(file.Size)}).",
            "success",
            new
            {
                selected = true,
                handleCount = count,
                file = new
                {
                    file.Name,
                    file.Type,
                    sizeBytes = file.Size,
                    file.LastModified,
                    lastModifiedUtc = lastModified,
                    file.WebkitRelativePath
                },
                proxiesDisposed = true
            },
            new("Name", file.Name),
            new("MIME type", file.Type.Length == 0 ? "Not provided" : file.Type),
            new("Size", FormatBytes(file.Size)),
            new("Modified", lastModified.ToLocalTime().ToString("g")));
    }

