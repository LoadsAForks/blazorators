    async Task RequestPersistenceAsync()
    {
        _actionRunning = true;
        _result = DemoResult.Running;
        try
        {
            await using var window = await Browser.GetWindowProxyAsync();
            await using var navigator = window.Navigator;
            await using var storage = navigator.Storage;
