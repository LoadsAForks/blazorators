    void SetProbeUnavailable(string response)
    {
        _phase = "unavailable";
        _readingLabel = "Feature detection";
        _reading = response;
        _result = CreateUnavailableResult(
            $"Browser entry point unavailable: {response}");
    }

    DemoResult CreateUnavailableResult(string message) =>
        CreateResult(
            message,
            "warning",
            new { status = "unavailable", message },
            new DemoFact("Status", "Unavailable"));

    static bool IsExpectedBrowserFailure(Exception exception) =>
        exception is JSException
            or DomTransportException
            or ArgumentNullException;

    static bool IsMissingApiFailure(Exception exception) =>
        exception is DomTransportException or ArgumentNullException;

    DemoResult CreateResult(
        string summary,
        string tone,
        object payload,
        params DemoFact[] facts)
        => CreateOperationResult(
            ActionExpression,
            ActionTransport,
            summary,
            tone,
            payload,
            facts);

    DemoResult CreateOperationResult(
        string operation,
        string transport,
        string summary,
        string tone,
        object payload,
        params DemoFact[] facts)
    {
        var envelope = new
        {
            capability = Definition.Slug,
            root = Definition.Roots,
            operation,
            transport,
            result = payload
        };

        return new(summary, tone, facts, JsonSerializer.Serialize(envelope, s_jsonOptions));
    }

    static string DisplayName(PermissionName permission) => permission switch
    {
        PermissionName.PersistentStorage => "Persistent storage",
        PermissionName.ScreenWakeLock => "Screen wake lock",
        PermissionName.StorageAccess => "Storage access",
        _ => permission.ToString()
    };

    static string StateTone(string state) => state switch
    {
        "granted" => "success",
        "denied" => "error",
        _ => "warning"
    };

    static string FormatBytes(double? bytes)
    {
        var value = bytes.GetValueOrDefault();
        if (value < 1024)
        {
            return $"{value:F0} B";
        }

        var units = new[] { "KB", "MB", "GB", "TB" };
        var unit = -1;
        do
        {
            value /= 1024;
            unit++;
        }
        while (value >= 1024 && unit < units.Length - 1);

        return $"{value:F1} {units[unit]}";
    }

    static string FirstLine(string value) =>
        value.Split(['\r', '\n'], StringSplitOptions.RemoveEmptyEntries).FirstOrDefault()
        ?? "The browser did not expose this capability.";

    public async ValueTask DisposeAsync()
    {
        if (_wakeLockSentinel is not null)
        {
            if (!_wakeLockSentinel.Released)
            {
                await _wakeLockSentinel.ReleaseAsync();
            }
            await _wakeLockSentinel.DisposeAsync();
        }

        if (_notification is not null)
        {
            _notification.Close();
            await _notification.DisposeAsync();
        }
    }

