        string Tone,
        IReadOnlyList<DemoFact> Facts,
        string? Json)
    {
        public static DemoResult Pending { get; } =
            new("Ready for interaction.", "neutral", [], null);

        public static DemoResult Running { get; } =
            new("Running generated interop...", "neutral", [], null);
    }

