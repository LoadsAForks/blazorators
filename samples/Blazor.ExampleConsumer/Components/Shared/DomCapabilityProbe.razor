    async Task<DemoResult> EnumerateDevicesAsync()
    {
        await using var window = await Browser.GetWindowProxyAsync();
        await using var navigator = window.Navigator;
        await using var mediaDevices = navigator.MediaDevices;
        await using var devices = await mediaDevices.EnumerateDevicesAsync();
        var count = await devices.GetLengthAsync();
        var snapshots = new List<MediaDeviceSnapshot>();

        for (var index = 0; index < count; index++)
        {
            await using var device = await devices.GetAsync(index);
            snapshots.Add(new(
                device.Kind.ToString(),
                device.Label,
                device.DeviceId,
                device.GroupId));
        }

        _mediaDevices = snapshots;
        return CreateResult(
            $"The browser returned {count} media device{(count == 1 ? "" : "s")}.",
            "success",
            new
            {
                count,
                labelsArePrivacyControlled = snapshots.Any(device => device.Label.Length == 0),
                devices = snapshots
            },
            new("Devices", count.ToString()),
            new("Named labels", snapshots.Count(device => device.Label.Length > 0).ToString()),
            new("Redacted labels", snapshots.Count(device => device.Label.Length == 0).ToString()));
    }

