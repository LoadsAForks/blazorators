        string Kind,
        string Label,
        string DeviceId,
        string GroupId)
    {
        public string DisplayLabel => Label.Length == 0 ? "Label hidden by browser" : Label;

        public string ShortId => DeviceId.Length <= 12
            ? DeviceId
            : $"{DeviceId[..8]}…{DeviceId[^4..]}";
    }
