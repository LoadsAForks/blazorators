    async Task<DemoResult> ToggleDemoCacheAsync()
    {
        var cacheName = _cacheName.Trim();
        if (cacheName.Length == 0)
        {
            return CreateResult(
                "Enter a cache name before running the operation.",
                "warning",
                new { validation = "cache-name-required" },
                new DemoFact("Cache name", "Required"));
        }

        await using var window = await Browser.GetWindowProxyAsync();
        await using var caches = window.Caches;
        var existedBefore = await caches.HasAsync(cacheName);
        string action;

        if (existedBefore)
        {
            var deleted = await caches.DeleteAsync(cacheName);
            action = deleted ? "removed" : "unchanged";
        }
        else
        {
            await using var cache = await caches.OpenAsync(cacheName);
            action = "created";
        }

        var existsAfter = await caches.HasAsync(cacheName);
        return CreateResult(
            $"Cache '{cacheName}' was {action}; exists now={existsAfter.ToString().ToLowerInvariant()}.",
            action == "unchanged" ? "warning" : "success",
            new { cacheName, existedBefore, action, existsAfter },
            new("Cache", cacheName),
            new("Before", existedBefore ? "Present" : "Missing"),
            new("After", existsAfter ? "Present" : "Missing"));
    }

