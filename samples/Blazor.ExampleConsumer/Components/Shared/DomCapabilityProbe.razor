@using Blazor.DOM
@using System.Text.Json
@using System.Text.Json.Serialization
@implements IAsyncDisposable
@inject IBrowser Browser

<section class="live-probe"
         aria-labelledby="live-probe-heading"
         data-probe="@Definition.Slug"
         data-probe-phase="@_phase">
    <div class="live-probe-heading">
        <span class="probe-signal @(_phase == "ready" ? "is-ready" : null)" aria-hidden="true"></span>
        <div>
            <span>Live browser contract</span>
            <h2 id="live-probe-heading">@ProbeTitle</h2>
        </div>
        <span class="probe-phase">@ProbePhase</span>
    </div>

    <dl class="probe-readiness">
        <div>
            <dt>Runtime context</dt>
            <dd data-probe-result="context">@_context</dd>
        </div>
        <div>
            <dt>@_readingLabel</dt>
            <dd data-probe-result="reading">@_reading</dd>
        </div>
        <div>
            <dt>User activation</dt>
            <dd data-probe-result="activation">@_activation</dd>
        </div>
    </dl>

    <div class="live-action">
        <div class="live-action-intro">
            <span>Interactive workflow</span>
            <h3>@ActionTitle</h3>
            <p>@ActionDescription</p>
        </div>

        <div class="workflow-grid">
            <section class="workflow-stage" data-workflow-step="configure">
                <div class="workflow-stage-heading">
                    <span>1</span>
                    <div>
                        <small>Configure</small>
                        <h4>@ConfigureTitle</h4>
                    </div>
                </div>
                <p>@ConfigureDescription</p>

                @if (Definition.Slug == "permissions")
                {
                    <label for="permission-demo-name">Permission name</label>
                    <select id="permission-demo-name" @bind="_permissionName">
                        <option value="@PermissionName.Geolocation">Geolocation</option>
                        <option value="@PermissionName.Camera">Camera</option>
                        <option value="@PermissionName.Microphone">Microphone</option>
                        <option value="@PermissionName.Notifications">Notifications</option>
                        <option value="@PermissionName.PersistentStorage">Persistent storage</option>
                    </select>
                }
                else if (Definition.Slug == "clipboard")
                {
                    <label for="clipboard-demo-value">Text to copy</label>
                    <textarea id="clipboard-demo-value"
                              rows="4"
                              @bind="_clipboardText"
                              @bind:event="oninput"
                              autocomplete="off"></textarea>
                    <small class="field-hint">@_clipboardText.Length characters will be written.</small>
                }
                else if (Definition.Slug == "web-share")
                {
                    <label for="share-demo-title">Share title</label>
                    <input id="share-demo-title"
                           @bind="_shareTitle"
                           @bind:event="oninput"
                           autocomplete="off" />
                    <label for="share-demo-value">Share text</label>
                    <textarea id="share-demo-value"
                              rows="3"
                              @bind="_shareText"
                              @bind:event="oninput"
                              autocomplete="off"></textarea>
                }
                else if (Definition.Slug == "performance")
                {
                    <label for="performance-demo-delay">Target workload delay</label>
                    <input id="performance-demo-delay"
                           type="range"
                           min="25"
                           max="500"
                           step="25"
                           @bind="_performanceDelay" />
                    <output class="range-value" for="performance-demo-delay">@_performanceDelay ms</output>
                }
                else if (Definition.Slug == "offline-storage")
                {
                    <label for="cache-demo-name">Cache name</label>
                    <input id="cache-demo-name"
                           @bind="_cacheName"
                           @bind:event="oninput"
                           autocomplete="off" />
                }
                else if (Definition.Slug == "notifications")
                {
                    <label for="notification-demo-title">Notification title</label>
                    <input id="notification-demo-title"
                           @bind="_notificationTitle"
                           @bind:event="oninput"
                           autocomplete="off" />
                    <label for="notification-demo-body">Notification body</label>
                    <textarea id="notification-demo-body"
                              rows="3"
                              @bind="_notificationBody"
                              @bind:event="oninput"
                              autocomplete="off"></textarea>
                }
                else
                {
                    <div class="configure-token">
                        <Icon Name="@Definition.Icon" />
                        <span>@ConfigureToken</span>
                    </div>
                }
            </section>

            <section class="workflow-stage workflow-run" data-workflow-step="run">
                <div class="workflow-stage-heading">
                    <span>2</span>
                    <div>
                        <small>Run</small>
                        <h4>Invoke the generated member</h4>
                    </div>
                </div>
                <p>The call below is dispatched directly against the explicit browser root.</p>

                <div class="operation-trace">
                    <code>@ActionExpression</code>
                    <span>@ActionTransport</span>
                </div>

                <div class="live-action-controls">
                    <button id="capability-action"
                            class="btn btn-primary"
                            type="button"
                            disabled="@(_actionRunning || _phase != "ready")"
                            @onclick="RunActionAsync">
                        <Icon Name="@ActionIcon" />
                        @ActionButtonLabel
                    </button>

                    @if (Definition.Slug == "web-share" && _canShare)
                    {
                        <button id="share-action"
                                class="btn btn-ghost"
                                type="button"
                                disabled="@(_actionRunning || _phase != "ready")"
                                @onclick="SharePayloadAsync">
                            <Icon Name="navigation" />
                            Open share sheet
                        </button>
                    }
                    else if (Definition.Slug == "storage-management")
                    {
                        <button id="storage-persist-action"
                                class="btn btn-ghost"
                                type="button"
                                disabled="@(_actionRunning || _phase != "ready")"
                                @onclick="RequestPersistenceAsync">
                            <Icon Name="database" />
                            Request persistence
                        </button>
                    }
                    else if (Definition.Slug == "notifications"
                             && _notificationPermission == NotificationPermission.Granted)
                    {
                        <button id="notification-show-action"
                                class="btn btn-ghost"
                                type="button"
                                disabled="@(_actionRunning || _phase != "ready")"
                                @onclick="ShowNotificationAsync">
                            <Icon Name="info" />
                            Show notification
                        </button>
                    }
                </div>
            </section>

            <section class="workflow-stage workflow-result" data-workflow-step="verify">
                <div class="workflow-stage-heading">
                    <span>3</span>
                    <div>
                        <small>Verify</small>
                        <h4>Inspect what the browser returned</h4>
                    </div>
                </div>
                <p>@VerifyDescription</p>

                <output class="result-summary result-@_result.Tone"
                        role="status"
                        aria-live="polite"
                        data-demo-result="@Definition.Slug">@_result.Summary</output>

                @if (_result.Facts.Count > 0)
                {
                    <dl class="result-facts">
                        @foreach (var fact in _result.Facts)
                        {
                            <div>
                                <dt>@fact.Label</dt>
                                <dd>@fact.Value</dd>
                            </div>
                        }
                    </dl>
                }

                @if (Definition.Slug == "clipboard")
                {
                    <div class="clipboard-verifier">
                        <label for="clipboard-paste-target">Paste from your clipboard to verify</label>
                        <textarea id="clipboard-paste-target"
                                  rows="4"
                                  @bind="_clipboardPasteText"
                                  @bind:event="oninput"
                                  autocomplete="off"
                                  placeholder="Press Ctrl+V or Command+V here"></textarea>
                        <output class="verification-state is-@ClipboardVerificationTone"
                                data-clipboard-verification="@ClipboardVerificationTone">
                            <Icon Name="@ClipboardVerificationIcon" />
                            @ClipboardVerification
                        </output>
                    </div>
                }
                else if (Definition.Slug == "storage-management" && _storageQuota > 0)
                {
                    <div class="storage-visual" aria-label="Storage usage">
                        <div>
                            <span>@FormatBytes(_storageUsage) used</span>
                            <span>@FormatBytes(_storageQuota) quota</span>
                        </div>
                        <progress value="@_storageUsage" max="@_storageQuota"></progress>
                    </div>
                }
                else if (Definition.Slug == "media-devices" && _mediaDevices.Count > 0)
                {
                    <ul class="device-results" aria-label="Enumerated media devices">
                        @foreach (var device in _mediaDevices)
                        {
                            <li>
                                <Icon Name="mic" />
                                <span>
                                    <strong>@device.DisplayLabel</strong>
                                    <small>@device.Kind · @device.ShortId</small>
                                </span>
                            </li>
                        }
                    </ul>
                }
                else if (Definition.Slug == "web-crypto" && _uuidHistory.Count > 0)
                {
                    <ol class="uuid-history" aria-label="Generated UUID history">
                        @foreach (var uuid in _uuidHistory)
                        {
                            <li><code>@uuid</code></li>
                        }
                    </ol>
                }
            </section>
        </div>

        @if (_result.Json is not null)
        {
            <details class="raw-result" open>
                <summary>
                    <span>
                        <Icon Name="code" />
                        Raw result envelope
                    </span>
                    <small>Exact sample values and transport metadata</small>
                </summary>
                <CodeSnippet @key="_result.Json"
                             Source="@_result.Json"
                             Language="json"
                             FileName="@($"{Definition.Slug}-result.json")"
                             Label="@($"{Definition.Name} raw result JSON")" />
            </details>
        }
    </div>

    <footer>
        <Icon Name="code" />
        <span>@Definition.Operations generated host operations; no handwritten JavaScript adapter.</span>
    </footer>
</section>

@code {
    static readonly JsonSerializerOptions s_jsonOptions = new()
    {
        WriteIndented = true,
        PropertyNamingPolicy = JsonNamingPolicy.CamelCase,
        DefaultIgnoreCondition = JsonIgnoreCondition.WhenWritingNull,
        Converters = { new JsonStringEnumConverter(JsonNamingPolicy.CamelCase) }
    };

    [Parameter, EditorRequired]
    public DomCapabilityDefinition Definition { get; set; } = null!;

    string _phase = "loading";
    string _context = "Connecting";
    string _readingLabel = "Generated root";
    string _reading = "Waiting";
    string _activation = "Waiting";
    DemoResult _result = DemoResult.Pending;
    PermissionName _permissionName = PermissionName.Geolocation;
    string _clipboardText = "Hello from Blazorators";
    string _clipboardPasteText = string.Empty;
    string _shareTitle = "Blazorators DOM lab";
    string _shareText = "Generated browser APIs for Blazor";
    string _cacheName = "blazorators-dom-demo";
    string _notificationTitle = "Blazorators DOM lab";
    string _notificationBody = "The generated Notifications API is working.";
    int _performanceDelay = 75;
    bool _actionRunning;
    bool _canShare;
    double _storageUsage;
    double _storageQuota;
    bool _storagePersisted;
    NotificationPermission _notificationPermission = NotificationPermission.Default;
    IWakeLockSentinel? _wakeLockSentinel;
    INotification? _notification;
    List<MediaDeviceSnapshot> _mediaDevices = [];
    List<string> _uuidHistory = [];

    string ProbeTitle => _phase switch
    {
        "ready" => "Generated API is responding",
        "unavailable" => "Browser support is unavailable",
        _ => "Resolving generated roots"
    };

    string ProbePhase => _phase switch
    {
        "ready" => "Ready",
        "unavailable" => "Unavailable",
        _ => "Running"
    };

    string ActionTitle => Definition.Slug switch
    {
        "permissions" => "Query a real permission",
        "clipboard" => "Complete a clipboard round trip",
        "web-share" => "Validate and share a typed payload",
        "wake-lock" => "Control the screen wake lock",
        "storage-management" => "Inspect origin storage",
        "screen" => "Compare screen and viewport geometry",
        "performance" => "Measure an async workload",
        "web-crypto" => "Generate secure identifiers",
        "credentials" => "Require explicit credential access",
        "offline-storage" => "Toggle a named application cache",
        "browser-coordination" => "Inspect the Web Locks queue",
        "media-devices" => "Enumerate available devices",
        "notifications" => "Request permission and notify",
        "file-system-access" => "Inspect a user-selected file",
        _ => "Run the generated API"
    };

    string ActionDescription => Definition.Slug switch
    {
        "clipboard" => "Write from the user gesture, then paste manually to verify the exact system clipboard value without requesting read permission.",
        "web-share" => "Build a typed ShareData dictionary, validate it, and expose the native share action only when the browser accepts it.",
        "wake-lock" => "Acquire an owned sentinel, inspect its state, then release and dispose the same browser proxy.",
        "storage-management" => "Read numeric usage and quota values, visualize their ratio, and optionally request persistent storage.",
        "notifications" => "Permission remains a separate, visible decision. A notification can be created only after the browser reports granted.",
        "file-system-access" => "The browser owns the picker. Select a test file to inspect metadata through its generated File proxy, or cancel safely.",
        _ => "Configure a representative value, run the generated contract, then inspect both the visual result and raw JSON."
    };

    string ConfigureTitle => Definition.Slug switch
    {
        "permissions" => "Choose the browser policy",
        "clipboard" => "Enter a recognizable value",
        "web-share" => "Compose the share payload",
        "performance" => "Choose a workload duration",
        "offline-storage" => "Name the cache",
        "notifications" => "Author the notification",
        _ => "Confirm the browser context"
    };

    string ConfigureDescription => Definition.Slug switch
    {
        "permissions" => "The query reads state only; it does not prompt the user.",
        "clipboard" => "Use text you can recognize when it comes back through a real paste.",
        "web-share" => "Unset optional dictionary members are omitted instead of serialized as null.",
        "performance" => "The browser clock measures elapsed time; scheduling may make the result slightly longer.",
        "offline-storage" => "A cache name is origin-scoped and can be queried again after the operation.",
        "notifications" => "These values are used only if permission is granted and you choose to show the notification.",
        _ => "The readiness values above show whether this browser can run the sample safely."
    };

    string ConfigureToken => Definition.Slug switch
    {
        "wake-lock" => "Keep this page visible while the sentinel is active.",
        "storage-management" => "This origin's current storage bucket.",
        "screen" => "Resize this window before refreshing to compare values.",
        "web-crypto" => "The browser's cryptographically secure random source.",
        "credentials" => "This secure origin's credential mediation state.",
        "browser-coordination" => "The current origin's held and pending lock queues.",
        "media-devices" => "Labels may remain private until camera or microphone permission is granted.",
        "file-system-access" => "Use a disposable local file; the page reads metadata only.",
        _ => "Current browser runtime"
    };

    string VerifyDescription => Definition.Slug switch
    {
        "clipboard" => "A successful write is only half of the user journey. Paste below to prove the exact value crossed the system clipboard.",
        "media-devices" => "Privacy-redacted labels are still valid browser results; permission controls what can be revealed.",
        "file-system-access" => "Only metadata is displayed. The file handle and File proxy are disposed after the action.",
        _ => "The summary is optimized for people; the expandable JSON keeps the exact values available for debugging."
    };

    string ActionExpression => Definition.Slug switch
    {
        "permissions" => "navigator.permissions.query(descriptor)",
        "clipboard" => "navigator.clipboard.writeText(text)",
        "web-share" => "navigator.canShare(shareData)",
        "wake-lock" => _wakeLockSentinel is null
            ? "navigator.wakeLock.request(\"screen\")"
            : "wakeLockSentinel.release()",
        "storage-management" => "navigator.storage.estimate()",
        "screen" => "window.screen + window.innerWidth/innerHeight",
        "performance" => "performance.now()",
        "web-crypto" => "crypto.randomUUID()",
        "credentials" => "navigator.credentials.preventSilentAccess()",
        "offline-storage" => "caches.has/open/delete(cacheName)",
        "browser-coordination" => "navigator.locks.query()",
        "media-devices" => "navigator.mediaDevices.enumerateDevices()",
        "notifications" => "Notification.requestPermission()",
        "file-system-access" => "window.showOpenFilePicker(options)",
        _ => "generated browser operation"
    };

    string ActionTransport => Definition.Slug switch
    {
        "wake-lock" or "media-devices" or "file-system-access" => "Promise → owned live proxy",
        "clipboard" or "credentials" or "web-share" => "Typed JSON value → Promise",
        "web-crypto" or "screen" or "performance" => "Synchronous WebAssembly value",
        _ => "Typed structured result"
    };

    string ActionIcon => Definition.Slug switch
    {
        "clipboard" => "copy",
        "performance" => "refresh",
        "screen" => "monitor",
        "media-devices" => "mic",
        "offline-storage" or "storage-management" => "database",
        "file-system-access" => "code",
        _ => "play"
    };

    string ActionButtonLabel => Definition.Slug switch
    {
        "permissions" => "Query permission",
        "clipboard" => "Copy text",
        "web-share" => "Validate payload",
        "wake-lock" => _wakeLockSentinel is null ? "Acquire wake lock" : "Release wake lock",
        "storage-management" => "Refresh storage",
        "screen" => "Refresh geometry",
        "performance" => $"Measure {_performanceDelay} ms",
        "web-crypto" => "Generate UUID",
        "credentials" => "Prevent silent access",
        "offline-storage" => "Toggle cache",
        "browser-coordination" => "Query lock state",
        "media-devices" => "Enumerate devices",
        "notifications" => "Request permission",
        "file-system-access" => "Choose a file",
        _ => "Run demo"
    };

    string ClipboardVerification => string.IsNullOrEmpty(_clipboardPasteText)
        ? "Waiting for a real paste from the system clipboard."
        : string.Equals(_clipboardPasteText, _clipboardText, StringComparison.Ordinal)
            ? "Exact match. The clipboard round trip is verified."
            : "The pasted value does not match the source text yet.";

    string ClipboardVerificationTone => string.IsNullOrEmpty(_clipboardPasteText)
        ? "waiting"
        : string.Equals(_clipboardPasteText, _clipboardText, StringComparison.Ordinal)
            ? "verified"
            : "mismatch";

    string ClipboardVerificationIcon =>
        ClipboardVerificationTone == "verified" ? "check" : "info";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        try
        {
            var missingPath = await FindMissingFeatureAsync();
            if (missingPath is null)
            {
                await RunProbeAsync();
                _phase = "ready";
            }
            else
            {
                SetProbeUnavailable(
                    $"The browser does not expose {missingPath}.");
            }
        }
        catch (Exception ex) when (IsExpectedBrowserFailure(ex))
        {
            SetProbeUnavailable(FirstLine(ex.Message));
        }

        StateHasChanged();
    }

    async Task RunProbeAsync()
    {
        await using var window = await Browser.GetWindowProxyAsync();
        await using var document = window.Document;
        await using var navigator = window.Navigator;
        await using var activation = navigator.UserActivation;

        _context = window.IsSecureContext ? "Secure localhost context" : "Insecure context";
        _activation = activation.IsActive
            ? "Active now"
            : activation.HasBeenActive
                ? "Previously active"
                : "Not yet active";

        (_readingLabel, _reading) = Definition.Slug switch
        {
            "permissions" => await ProbePermissionsAsync(navigator),
            "clipboard" => await ProbeClipboardAsync(navigator),
            "web-share" => ProbeShare(navigator),
            "wake-lock" => await ProbeWakeLockAsync(navigator, document),
            "storage-management" => await ProbeStorageAsync(navigator),
            "screen" => await ProbeScreenAsync(window),
            "performance" => await ProbePerformanceAsync(window),
            "web-crypto" => await ProbeCryptoAsync(window),
            "credentials" => await ProbeCredentialsAsync(navigator),
            "offline-storage" => await ProbeOfflineStorageAsync(window),
            "browser-coordination" => await ProbeCoordinationAsync(navigator, document),
            "media-devices" => await ProbeMediaDevicesAsync(navigator),
            "notifications" => await ProbeNotificationsAsync(),
            "file-system-access" => ("Picker entry point", "window.showOpenFilePicker is available"),
            _ => throw new InvalidOperationException($"No live probe exists for '{Definition.Slug}'.")
        };
    }

    async Task RunActionAsync()
    {
        if (_phase != "ready")
        {
            _result = CreateUnavailableResult(
                "Feature detection did not find every browser entry point required by this workflow.");
            return;
        }

        _actionRunning = true;
        _result = DemoResult.Running;

        try
        {
            _result = Definition.Slug switch
            {
                "permissions" => await QueryPermissionAsync(),
                "clipboard" => await WriteClipboardAsync(),
                "web-share" => await CheckShareAsync(),
                "wake-lock" => await ToggleWakeLockAsync(),
                "storage-management" => await RefreshStorageAsync(),
                "screen" => await RefreshScreenAsync(),
                "performance" => await MeasurePerformanceAsync(),
                "web-crypto" => await GenerateUuidAsync(),
                "credentials" => await PreventSilentAccessAsync(),
                "offline-storage" => await ToggleDemoCacheAsync(),
                "browser-coordination" => await QueryLocksAsync(),
                "media-devices" => await EnumerateDevicesAsync(),
                "notifications" => await RequestNotificationsAsync(),
                "file-system-access" => await ChooseFileAsync(),
                _ => throw new InvalidOperationException(
                    $"No interactive demo exists for '{Definition.Slug}'.")
            };
        }
        catch (Exception ex) when (IsExpectedBrowserFailure(ex))
        {
            var unavailable = IsMissingApiFailure(ex);
            if (unavailable)
            {
                SetProbeUnavailable(FirstLine(ex.Message));
            }
            _result = CreateResult(
                unavailable
                    ? $"Browser API unavailable: {FirstLine(ex.Message)}"
                    : $"Browser response: {FirstLine(ex.Message)}",
                unavailable ? "warning" : "error",
                new
                {
                    status = unavailable ? "unavailable" : "browser-error",
                    message = FirstLine(ex.Message)
                },
                new("Status", unavailable ? "Unavailable" : "Browser error"),
                new("Exception", ex.GetType().Name));
        }
        finally
        {
            _actionRunning = false;
        }
    }

    async Task<DemoResult> QueryPermissionAsync()
    {
        await using var window = await Browser.GetWindowProxyAsync();
        await using var navigator = window.Navigator;
        await using var permissions = navigator.Permissions;
        await using var status = await permissions.QueryAsync(
            new PermissionDescriptor { Name = _permissionName });
        var state = status.State.ToString().ToLowerInvariant();
        return CreateResult(
            $"{DisplayName(_permissionName)} is {state}.",
            StateTone(state),
            new { permission = _permissionName, state },
            new("Permission", DisplayName(_permissionName)),
            new("Typed state", state));
    }

    async Task<DemoResult> WriteClipboardAsync()
    {
        await using var window = await Browser.GetWindowProxyAsync();
        await using var navigator = window.Navigator;
        await using var clipboard = navigator.Clipboard;
        await clipboard.WriteTextAsync(_clipboardText);
        _clipboardPasteText = string.Empty;
        return CreateResult(
            $"Copied {_clipboardText.Length} characters. Paste into step 3 to verify.",
            "success",
            new
            {
                writeCompleted = true,
                charactersWritten = _clipboardText.Length,
                expectedText = _clipboardText
            },
            new("Promise", "Completed"),
            new("Characters", _clipboardText.Length.ToString()),
            new("Verification", "Paste required"));
    }

    async Task<DemoResult> CheckShareAsync()
    {
        await using var window = await Browser.GetWindowProxyAsync();
        await using var navigator = window.Navigator;
        var data = new ShareData { Title = _shareTitle, Text = _shareText };
        _canShare = navigator.CanShare(data);
        return CreateResult(
            _canShare
                ? "The browser accepts this payload. The native share action is now available."
                : "The browser does not expose a compatible share sheet for this payload.",
            _canShare ? "success" : "warning",
            new
            {
                title = _shareTitle,
                text = _shareText,
                canShare = _canShare
            },
            new("Payload", _canShare ? "Accepted" : "Rejected"),
            new("Title length", _shareTitle.Length.ToString()),
            new("Text length", _shareText.Length.ToString()));
    }

    async Task SharePayloadAsync()
    {
        _actionRunning = true;
        _result = DemoResult.Running;
        try
        {
            await using var window = await Browser.GetWindowProxyAsync();
            await using var navigator = window.Navigator;
            await navigator.ShareAsync(new ShareData { Title = _shareTitle, Text = _shareText });
            _result = CreateOperationResult(
                "navigator.share(shareData)",
                "Typed JSON value → Promise",
                "The native share workflow completed.",
                "success",
                new { title = _shareTitle, text = _shareText, shared = true },
                new("Share Promise", "Completed"),
                new("Browser UI", "Closed"));
        }
        catch (Exception ex) when (IsExpectedBrowserFailure(ex))
        {
            var unavailable = IsMissingApiFailure(ex);
            if (unavailable)
            {
                SetProbeUnavailable(FirstLine(ex.Message));
            }
            _result = CreateOperationResult(
                "navigator.share(shareData)",
                "Typed JSON value → Promise",
                unavailable
                    ? $"Share API unavailable: {FirstLine(ex.Message)}"
                    : $"Share sheet response: {FirstLine(ex.Message)}",
                "warning",
                new
                {
                    shared = false,
                    status = unavailable ? "unavailable" : "cancelled-or-rejected",
                    message = FirstLine(ex.Message)
                },
                new DemoFact(
                    "Share Promise",
                    unavailable ? "Unavailable" : "Cancelled or rejected"));
        }
        finally
        {
            _actionRunning = false;
        }
    }

    async Task<DemoResult> ToggleWakeLockAsync()
    {
        if (_wakeLockSentinel is not null)
        {
            await _wakeLockSentinel.ReleaseAsync();
            var released = _wakeLockSentinel.Released;
            await _wakeLockSentinel.DisposeAsync();
            _wakeLockSentinel = null;
            return CreateOperationResult(
                "wakeLockSentinel.release()",
                "Promise → owned live proxy",
                "Wake lock released and its live proxy disposed.",
                "success",
                new { state = "released", released, disposed = true },
                new("Sentinel", "Released"),
                new("Proxy", "Disposed"));
        }

        await using var window = await Browser.GetWindowProxyAsync();
        await using var navigator = window.Navigator;
        await using var wakeLock = navigator.WakeLock;
        _wakeLockSentinel = await wakeLock.RequestAsync(WakeLockType.Screen);
        return CreateResult(
            "Screen wake lock acquired. Use the same control to release it.",
            "success",
            new
            {
                state = "active",
                type = WakeLockType.Screen,
                released = _wakeLockSentinel.Released,
                ownedProxy = true
            },
            new("Sentinel", "Active"),
            new("Released", _wakeLockSentinel.Released.ToString().ToLowerInvariant()),
            new("Ownership", "Component"));
    }

