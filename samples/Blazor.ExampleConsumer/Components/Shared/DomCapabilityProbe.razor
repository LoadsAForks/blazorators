                    ? $"Storage API unavailable: {FirstLine(ex.Message)}"
                    : $"Persistence response: {FirstLine(ex.Message)}",
                unavailable ? "warning" : "error",
                new
                {
                    persisted = false,
                    status = unavailable ? "unavailable" : "browser-error",
                    message = FirstLine(ex.Message)
                },
                new DemoFact(
                    "Persistence",
                    unavailable ? "Unavailable" : "Browser error"));
        }
        finally
        {
            _actionRunning = false;
        }
    }

